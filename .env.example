# Example values only. Replace every credential before running outside local dev.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=your_postgres_db
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_POOL_MINCONN=1
POSTGRES_POOL_MAXCONN=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Bitcoin Core RPC
# Use credentials from your own bitcoin.conf rpcauth/rpcuser setup.
BTC_RPC_HOST=127.0.0.1
BTC_RPC_PORT=8332
BTC_RPC_USER=your_bitcoin_rpc_username
BTC_RPC_PASSWORD=your_bitcoin_rpc_password
BTC_RPC_TIMEOUT=30
BTC_LISTENER_SLEEP_SECONDS=10
BTC_LISTENER_ERROR_SLEEP_SECONDS=10
BTC_PRICE_TABLE=mq_btc_price_10m

# Workers / runtime loops
WORKER_RETRY_SLEEP_SECONDS=10
WORKER_HEARTBEAT_SECONDS=60
WORKER_STALE_AFTER_SECONDS=180
WORKER_STARTUP_REPLAY=true
PRICE_COMPOSER_SLEEP_SECONDS=30
PRICE_COMPOSER_TIMELINE_BACKBONE=btc_primitive_10m
PRICE_COMPOSER_WRITE_NULL_BUCKETS=true
PRICE_SOURCE_INGESTION_SLEEP_SECONDS=60
PRICE_REQUEST_TIMEOUT_SECONDS=30

# Local WS price source workers.
PRICE_WS_ENABLED=true
PRICE_WS_SOURCE=bybit
PRICE_WS_SYMBOL=BTCUSDT
PRICE_WS_CHILD_INTERVAL=1m
PRICE_WS_TARGET_INTERVAL=10m
PRICE_WS_BUCKET_GRACE_SECONDS=5
PRICE_WS_STALE_SECONDS=30
PRICE_WS_RECONNECT_BACKOFF_SECONDS=1,2,5,10
PRICE_WS_REST_FALLBACK_ENABLED=true
PRICE_WS_REST_CONFIRM_DELAY_SECONDS=30
PRICE_WS_PRICE_TOLERANCE_BPS=1
PRICE_WS_VOLUME_TOLERANCE_BPS=10
PRICE_WS_OUTPUT_MODE=local_db
PRICE_WS_REMOTE_INGEST_URL=http://localhost:8000/api/v1/internal/price/source/binance/10m
PRICE_WS_REMOTE_INGEST_TOKEN=replace_with_the_same_internal_ingest_token
PRICE_WS_REMOTE_TIMEOUT_SECONDS=10
PRICE_WS_REMOTE_MAX_ATTEMPTS=3

PRICE_SOURCE_LIFECYCLE_ENABLED=true
PRICE_SOURCE_LIFECYCLE_AUTOSTART_WS=true
PRICE_SOURCE_LIFECYCLE_SOURCES=bybit,okx,binance,coinbase,kraken,bitstamp
PRICE_SOURCE_REST_SYNC_ALLOWED_LAG_MINUTES=20
PRICE_SOURCE_WORKER_POLL_SECONDS=60
PRICE_SOURCE_WORKER_CONFIRMATION_POLL_SECONDS=1

# Internal authenticated ingest API for cloud source feeders.
# mqnode_cloud should POST Binance 10m rows to one of:
# - https://api.mamakquant.com/api/v1/internal/price/source/binance/10m
# - http://localhost:8000/api/v1/internal/price/source/binance/10m
MQNODE_INTERNAL_INGEST_TOKEN=replace_with_a_long_random_token

# Application logging
LOG_LEVEL=INFO
